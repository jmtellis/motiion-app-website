# Beta signup (API route)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Profile / activity link previews + shortlist review (same Supabase project as the iOS app)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Resume parsing during onboarding (same key as iOS / Supabase edge functions)
OPENAI_API_KEY=

# Working location search uses public Nominatim (OpenStreetMap). Optional overrides:
# NOMINATIM_USER_AGENT=MotiionWeb/1.0 (https://www.motiion.app; contact@example.com)
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Optional: override OG image function base (default: ${NEXT_PUBLIC_SUPABASE_URL}/functions/v1/profile-og)
# NEXT_PUBLIC_PROFILE_OG_BASE_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/profile-og

# Canonical origin for Open Graph / metadata (e.g. https://www.motiion.app)
NEXT_PUBLIC_SITE_URL=https://www.motiion.app
