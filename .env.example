# =============================================================================
# Motiion Web — environment variables
# Copy to `.env.local` for local development. Set the same keys in Vercel.
# See README.md for setup order and service links.
# =============================================================================

# --- Supabase (required for auth, data, storage, realtime) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-only: admin analytics + webhook handlers (never expose as NEXT_PUBLIC_*)
SUPABASE_SERVICE_ROLE_KEY=

# --- Site / app URLs ---
NEXT_PUBLIC_SITE_URL=https://www.motiion.app
# Used by OAuth callback and share links (defaults to localhost in dev)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe (industry subscriptions; server-only except publishable key) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price ID for the single Industry Pro tier (price_...)
STRIPE_INDUSTRY_PRICE_ID=
# Set to "true" to hard-gate advanced search/rosters/projects behind the paid tier
ENFORCE_INDUSTRY_PAYWALL=false

# --- RevenueCat (iOS IAP entitlement sync) ---
REVENUECAT_WEBHOOK_SECRET=

# --- Resend (transactional / notification email) ---
RESEND_API_KEY=
# Shared secret required by POST /api/notifications/email (DB webhooks / edge functions)
INTERNAL_EMAIL_TOKEN=

# --- PostHog (product analytics) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Sentry (client + server error tracking) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Beta signup (marketing API route) ---
NOTION_API_KEY=
NOTION_DATABASE_ID=

# --- Brandfetch (company logos + Client company search; same key as iOS Secrets.xcconfig) ---
BRANDFETCH_CLIENT_ID=
NEXT_PUBLIC_BRANDFETCH_CLIENT_ID=

# --- Spotify (Client artist search; Client Credentials; server-only) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- TMDB (Client film/TV project search; server-only preferred) ---
TMDB_API_KEY=
# NEXT_PUBLIC_TMDB_API_KEY=

# --- OpenAI (resume parsing + NL talent search on /talent) ---
OPENAI_API_KEY=

# --- Working location search (public Nominatim / OpenStreetMap) ---
# NOMINATIM_USER_AGENT=MotiionWeb/1.0 (https://www.motiion.app; contact@example.com)
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# --- Google Places (establishments + cities autocomplete; server-only) ---
GOOGLE_PLACES_API_KEY=

# --- Optional: override OG image function base ---
# NEXT_PUBLIC_PROFILE_OG_BASE_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/profile-og

# OAuth (Google + Apple): in Supabase Dashboard → Authentication → URL Configuration, add:
#   https://www.motiion.app/auth/callback
#   http://localhost:3000/auth/callback
# Enable Google and Apple providers under Authentication → Providers (same project as iOS).
